{
    "extends": "@react-native/typescript-config",
    "compilerOptions": {
        "types": [
            "jest"
        ],
        "typesRoots": [
            "./src/types"
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ],
    "exclude": [
        "**/node_modules",
        "**/Pods"
    ]
}
